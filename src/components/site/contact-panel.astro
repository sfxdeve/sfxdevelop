---
import type { ContactItem } from "../../data/profile";

interface Props {
  contacts: ContactItem[];
}

const { contacts } = Astro.props;
---

<section class="brutal-frame p-6 md:p-8">
  <h2 class="text-3xl font-black uppercase leading-tight md:text-4xl">Start A Conversation</h2>
  <p class="mt-3 max-w-2xl text-base leading-relaxed">
    If you are hiring for full stack JavaScript roles, use the channels below and I will respond quickly.
  </p>

  <ul class="mt-8 grid gap-4 md:grid-cols-2">
    {
      contacts.map((contact) => (
        <li class="border-2 border-ink bg-paper p-4">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-ink/80">{contact.label}</p>
          {contact.href ? (
            <a
              href={contact.href}
              class="mt-2 inline-flex break-all text-base font-bold underline decoration-2 underline-offset-4"
              target={contact.href.startsWith("http") ? "_blank" : undefined}
              rel={contact.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {contact.value}
            </a>
          ) : (
            <p class="mt-2 text-base font-bold">{contact.value}</p>
          )}
        </li>
      ))
    }
  </ul>

  <a
    href="mailto:sfx.deve@gmail.com?subject=Hiring%20Inquiry%20-%20Full%20Stack%20JavaScript%20Role"
    class="hover-lift mt-8 inline-flex border-2 border-ink bg-acid px-5 py-3 text-sm font-bold uppercase tracking-[0.15em] no-underline"
  >
    Email For Recruiter Inquiry
  </a>
</section>
