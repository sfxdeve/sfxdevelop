---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  as?: "h1" | "h2";
}

const { eyebrow, title, intro, as = "h2" } = Astro.props;
const HeadingTag = as;
---

<div class="space-y-4">
  {eyebrow && (
    <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-ink/80">{eyebrow}</p>
  )}
  <HeadingTag class="max-w-4xl text-balance text-4xl font-black uppercase leading-[0.95] tracking-tight md:text-6xl">
    {title}
  </HeadingTag>
  {intro && <p class="max-w-3xl text-base leading-relaxed md:text-lg">{intro}</p>}
</div>
