---
import type { ExperienceItem } from "../../data/profile";

interface Props {
  item: ExperienceItem;
}

const { item } = Astro.props;
---

<article class="brutal-frame hover-lift flex h-full flex-col p-5 md:p-7">
  <div class="space-y-3">
    <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-ink/80">{item.period}</p>
    <h2 class="text-2xl font-black uppercase leading-tight md:text-3xl">{item.role}</h2>
    <p class="text-sm font-bold uppercase tracking-[0.12em]">{item.company} · {item.location} · {item.arrangement}</p>
    <p class="text-base leading-relaxed">{item.scope}</p>
  </div>

  <ul class="mt-6 space-y-2">
    {
      item.highlights.map((highlight) => (
        <li class="border-l-4 border-ink pl-3 text-sm leading-relaxed">{highlight}</li>
      ))
    }
  </ul>

  <p class="mt-6 border-t-2 border-ink pt-4 text-sm leading-relaxed">
    <span class="font-bold uppercase tracking-[0.08em]">Impact:</span> {item.impact}
  </p>

  <div class="mt-4 flex flex-wrap gap-2">
    {
      item.stack.map((tech) => (
        <span class="brutal-chip">{tech}</span>
      ))
    }
  </div>
</article>
