---
import type { SkillCategory } from "../../types/portfolio";
import BrutalistCard from "./brutalist-card.astro";
import Tag from "../ui/tag.astro";

interface Props {
  categories: SkillCategory[];
}

const { categories } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  {categories.map((group, index) => (
    <BrutalistCard className="h-full" accent={index % 3 === 2 ? "safety" : "acid"}>
      <h3 class="mb-4 font-display text-3xl uppercase leading-none tracking-[0.06em] text-paper-50">
        {group.category}
      </h3>
      <div class="flex flex-wrap gap-2">
        {group.items.map((skill) => <Tag text={skill} className="border-paper-300 text-paper-100" />)}
      </div>
    </BrutalistCard>
  ))}
</div>
